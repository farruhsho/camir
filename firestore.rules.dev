rules_version = '2';

// ⚠️ LOCAL DEV ONLY — never deploy to prod.
// ⚠️ ТОЛЬКО ЛОКАЛЬНАЯ РАЗРАБОТКА — не деплоить в продакшен.
//
// Открытые dev-правила «Цадмир»: любой аутентифицированный клиент читает и
// пишет всё. Удобно для локального цикла (демо-роли, быстрый вход), но НЕ
// защищает данные. Прод деплоится строго с firestore.rules (ролевые правила,
// deny-by-default), на который указывает firebase.json.
//
// Локально: firebase deploy --only firestore:rules --config <dev-config>, либо
// временно скопируйте этот файл поверх firestore.rules для эмулятора.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
