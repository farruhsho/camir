rules_version = '2';

// ПРОДАКШЕН-ПРАВИЛА «Цадмир» (проект cadmir-erp, europe-west1).
//
// Модель безопасности: deny-by-default + ролевой доступ + ИЗОЛЯЦИЯ КЛИНИК.
// Роль и права сотрудника хранятся в staff/{uid} (поля is_superuser,
// permissions[], role, clinic_id, is_platform_admin) и пишутся сервером/консолью
// — клиент НЕ может выдать их себе (см. staff ниже). Коды прав совпадают с
// lib/core/auth/role_catalog.dart.
//
// Мульти-клиничность: каждый бизнес-документ несёт поле `clinic_id` (String).
// Сотрудник видит и меняет ТОЛЬКО документы своей клиники
// (resource.data.clinic_id == staff/{uid}.clinic_id), и не может ни создать, ни
// «увести» документ в чужую клинику. Платформенный администратор
// (is_platform_admin) управляет коллекцией clinics и заводит клиникам первого
// супер-админа; его доступ к операционным данным всё равно ограничен его
// собственной клиникой. Изоляцию дублирует клиент (ClinicScope), но граница
// безопасности — здесь.
//
// Локальная разработка: используйте firestore.rules.dev (открытые правила),
// прод деплоится строго с этого файла (см. firebase.json).
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isSignedIn() {
      return request.auth != null;
    }
    // Есть ли у вошедшего профиль staff/{uid} (exists() защищает get() от
    // ошибки на несуществующем документе — напр. при самрегистрации).
    function hasStaff() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    // Профиль сотрудника, инициировавшего запрос (staff/{uid}).
    function staffData() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }
    // Активный сотрудник с профилем и НЕ отключённый (disabled != true).
    function isActive() {
      return hasStaff() && staffData().disabled != true;
    }
    function isSuper() {
      return isActive() && staffData().is_superuser == true;
    }
    // Есть ли у сотрудника право p (супер-админ имеет все права).
    function hasPerm(p) {
      return isActive() && (
        staffData().is_superuser == true ||
        (staffData().permissions is list && staffData().permissions.hasAny([p]))
      );
    }

    // ---- мульти-клиничность ----
    // Клиника текущего сотрудника. Вызывается только после isActive()/hasPerm()
    // (короткое замыкание &&), поэтому staff/{uid} гарантированно существует.
    function myClinic() {
      return staffData().clinic_id;
    }
    // Платформенный администратор (управляет клиниками, заводит им админов).
    function isPlatform() {
      return isActive() && staffData().is_platform_admin == true;
    }
    // Существующий документ принадлежит клинике сотрудника (read/update/delete).
    function sameClinic() {
      return resource.data.clinic_id == myClinic();
    }
    // Записываемый документ адресован клинике сотрудника (create/update) —
    // отсекает создание чужих и «увод» в другую клинику.
    function createSameClinic() {
      return request.resource.data.clinic_id == myClinic();
    }

    // ---- пациенты ----
    match /patients/{id} {
      allow read: if hasPerm('patients.read') && sameClinic();
      allow create: if hasPerm('patients.create') && createSameClinic();
      allow update: if hasPerm('patients.update')
        && sameClinic() && createSameClinic();
      allow delete: if isSuper() && sameClinic();
    }

    // ---- визиты (регистратура/очередь) ----
    match /visits/{id} {
      allow read: if hasPerm('visits.read') && sameClinic();
      allow create: if hasPerm('visits.create') && createSameClinic();
      allow update: if hasPerm('visits.update')
        && sameClinic() && createSameClinic();
      allow delete: if isSuper() && sameClinic();
    }

    // ---- анализы ----
    match /analyses/{id} {
      allow read: if hasPerm('analyses.read') && sameClinic();
      allow create: if hasPerm('analyses.write') && createSameClinic();
      allow update: if hasPerm('analyses.write')
        && sameClinic() && createSameClinic();
      // Кто может править журнал — может и удалить ошибочную запись (UI и
      // правила согласованы; правка уже позволяет менять любое поле).
      allow delete: if hasPerm('analyses.write') && sameClinic();
    }

    // ---- фиброскан ----
    match /fibroscan/{id} {
      allow read: if hasPerm('fibroscan.read') && sameClinic();
      allow create: if hasPerm('fibroscan.write') && createSameClinic();
      allow update: if hasPerm('fibroscan.write')
        && sameClinic() && createSameClinic();
      allow delete: if hasPerm('fibroscan.write') && sameClinic();
    }

    // ---- склад: номенклатура ----
    match /products/{id} {
      allow read: if hasPerm('inventory.read') && sameClinic();
      allow create: if hasPerm('inventory.manage') && createSameClinic();
      allow update: if hasPerm('inventory.manage')
        && sameClinic() && createSameClinic();
      allow delete: if isSuper() && sameClinic();
    }

    // ---- склад: движения (приход/списание) ----
    match /stock_movements/{id} {
      allow read: if hasPerm('inventory.read') && sameClinic();
      allow create: if (hasPerm('inventory.write_off')
          || hasPerm('inventory.manage'))
        && createSameClinic();
      allow update: if isSuper() && sameClinic() && createSameClinic();
      allow delete: if isSuper() && sameClinic();
    }

    // ---- касса: платежи (append-only; возврат = единственная правка) ----
    match /payments/{id} {
      allow read: if hasPerm('payments.read') && sameClinic();
      // Создаёт кассир; фиксируем автора и стартовый статус.
      allow create: if hasPerm('payments.create')
        && request.resource.data.status == 'paid'
        && request.resource.data.created_by == request.auth.uid
        && createSameClinic();
      // Единственная разрешённая правка — возврат: paid -> refunded, при этом
      // сумма/состав/день/способ/имя пациента НЕ меняются. Это же отсекает
      // двойной возврат (из refunded перейти нельзя). Клиника обязана совпадать
      // до и после (sameClinic + createSameClinic).
      allow update: if hasPerm('payments.refund')
        && resource.data.status == 'paid'
        && request.resource.data.status == 'refunded'
        && request.resource.data.total == resource.data.total
        && request.resource.data.items == resource.data.items
        && request.resource.data.day == resource.data.day
        && request.resource.data.method == resource.data.method
        && request.resource.data.patient_name == resource.data.patient_name
        && request.resource.data.created_by == resource.data.created_by
        && request.resource.data.created_at == resource.data.created_at
        && request.resource.data.get('patient_id', '')
             == resource.data.get('patient_id', '')
        && request.resource.data.get('mrn', '') == resource.data.get('mrn', '')
        && sameClinic()
        && createSameClinic();
      allow delete: if isSuper() && sameClinic();
    }

    // ---- касса: прайс-лист услуг (кассир читает, чтобы собрать чек) ----
    match /services/{id} {
      allow read: if (hasPerm('services.read') || hasPerm('payments.create'))
        && sameClinic();
      allow create: if hasPerm('services.manage') && createSameClinic();
      allow update: if hasPerm('services.manage')
        && sameClinic() && createSameClinic();
      allow delete: if isSuper() && sameClinic();
    }

    // ---- касса: смены (открытие/закрытие; учёт append-only) ----
    match /cash_shifts/{id} {
      allow read: if hasPerm('payments.read') && sameClinic();
      // Открывает кассир; фиксируем автора и стартовый статус `open`.
      allow create: if hasPerm('payments.create')
        && request.resource.data.status == 'open'
        && request.resource.data.opened_by == request.auth.uid
        && createSameClinic();
      // Единственная правка — закрытие смены: open -> closed, при этом
      // начальный остаток/день/автор открытия НЕ меняются (реконсиляция
      // должна сходиться; повторное закрытие отсекается — из closed нельзя).
      allow update: if hasPerm('payments.create')
        && resource.data.status == 'open'
        && request.resource.data.status == 'closed'
        && request.resource.data.opening_amount == resource.data.opening_amount
        && request.resource.data.day == resource.data.day
        && request.resource.data.opened_by == resource.data.opened_by
        && sameClinic()
        && createSameClinic();
      allow delete: if isSuper() && sameClinic();
    }

    // ---- касса: изъятия наличных (append-only, только создание) ----
    match /cash_withdrawals/{id} {
      allow read: if hasPerm('payments.read') && sameClinic();
      // Оформляет кассир; фиксируем автора. Правка запрещена (append-only),
      // удалить ошибочную запись может только супер-админ.
      allow create: if hasPerm('payments.create')
        && request.resource.data.created_by == request.auth.uid
        && createSameClinic();
      allow update: if false;
      allow delete: if isSuper() && sameClinic();
    }

    // ---- счётчики (MRN / номер очереди) — нужны в транзакциях создания
    // карты пациента и визита. Доступ только тем, кто реально создаёт записи,
    // чтобы «обезоруженный» новый аккаунт не мог накручивать счётчики.
    // Изоляция клиник обеспечена схемой id: counters/{clinic_id}__patients и
    // counters/{clinic_id}__queue-<день> — у документа счётчика нет поля
    // clinic_id, поэтому здесь оставляем ролевую проверку без sameClinic(). ----
    match /counters/{doc} {
      allow read, write: if hasPerm('patients.create') || hasPerm('visits.create');
    }

    // ---- сотрудники ----
    // Читать свой профиль может сам сотрудник; ВСЕ профили — платформенный
    // админ; клинический супер-админ — только сотрудников СВОЕЙ клиники.
    // Самостоятельная регистрация разрешена ТОЛЬКО «обезоруженной»: uid == свой,
    // is_superuser == false, без прав/роли, clinic_id == '' и без платформенного
    // флага — клинику и роль назначает супер-админ позже (у нового профиля прав
    // нет, поэтому до назначения он не видит данных). Клинический супер-админ
    // заводит/правит/удаляет сотрудников ТОЛЬКО своей клиники и НЕ может ни
    // выдать is_platform_admin, ни «увести» сотрудника в другую клинику —
    // это закрывает самоэскалацию и межклиничные вмешательства.
    match /staff/{uid} {
      allow read: if request.auth.uid == uid
        || isPlatform()
        || (isSuper() && resource.data.clinic_id == myClinic());
      // Платформенный админ заводит кого угодно; клинический супер-админ —
      // только в свою клинику и без платформенного флага. Самостоятельная
      // регистрация — строго «обезоруженная» (см. выше). Роль нельзя выставить
      // себе — иначе клиент поднял бы себе доступ.
      allow create: if isPlatform()
        || (isSuper()
            && request.resource.data.clinic_id == myClinic()
            && request.resource.data.get('is_platform_admin', false) != true)
        || (request.auth.uid == uid
            && request.resource.data.is_superuser == false
            && (!('permissions' in request.resource.data)
                || request.resource.data.permissions.size() == 0)
            && (!('role' in request.resource.data)
                || request.resource.data.role == '')
            && request.resource.data.get('clinic_id', '') == ''
            && request.resource.data.get('is_platform_admin', false) != true);
      // ⚠️ ВРЕМЕННО — УБРАТЬ ПЕРЕД ПРОДОМ (эта одна строка + кнопка на входе).
      // Кнопка «Регистрация супер-админа» разрешает завести СВОЙ staff-док с
      // любыми правами (супер + платформенный). Это самоэскалация — снять.
      allow create: if request.auth.uid == uid; // TEMP-SUPER-SIGNUP
      // Правка супером: только своя клиника; платформенный флаг и клиника
      // сотрудника при этом НЕ меняются (get с дефолтом — поля могло не быть).
      allow update: if isPlatform()
        || (isSuper()
            && resource.data.clinic_id == myClinic()
            && request.resource.data.get('is_platform_admin', false)
                 == resource.data.get('is_platform_admin', false)
            && request.resource.data.get('clinic_id', '')
                 == resource.data.get('clinic_id', ''));
      allow delete: if isPlatform()
        || (isSuper() && resource.data.clinic_id == myClinic());
    }

    // ---- аудит (append-only) ----
    // Создавать может только активный сотрудник, от своего имени и в свою
    // клинику; читать — держатель audit.read/супер-админ в рамках своей
    // клиники; редактировать/удалять нельзя (append-only журнал).
    match /audit/{doc} {
      allow create: if isActive()
        && request.resource.data.created_by == request.auth.uid
        && createSameClinic();
      allow read: if (hasPerm('audit.read') || isSuper()) && sameClinic();
      allow update, delete: if false;
    }

    // ---- справочник типов анализов (каталог, свой на клинику) ----
    // Читать может любой активный сотрудник своей клиники (нужно везде, где
    // выбирают тип анализа); править — держатель catalog.manage (супер-админ
    // неявно), только в своей клинике.
    match /analysis_types/{id} {
      allow read: if isActive() && sameClinic();
      allow create: if hasPerm('catalog.manage') && createSameClinic();
      allow update: if hasPerm('catalog.manage')
        && sameClinic() && createSameClinic();
      allow delete: if hasPerm('catalog.manage') && sameClinic();
    }

    // ---- справочник референсов фиброскана (каталог, свой на клинику) ----
    match /fibroscan_refs/{id} {
      allow read: if isActive() && sameClinic();
      allow create: if hasPerm('catalog.manage') && createSameClinic();
      allow update: if hasPerm('catalog.manage')
        && sameClinic() && createSameClinic();
      allow delete: if hasPerm('catalog.manage') && sameClinic();
    }

    // ---- склад: справочник категорий товаров (каталог, свой на клинику) ----
    // Читать может любой активный сотрудник своей клиники (нужно при выборе
    // категории товара); управлять — держатель inventory.manage (супер-админ
    // неявно), только в своей клинике.
    match /product_categories/{id} {
      allow read: if isActive() && sameClinic();
      allow create: if hasPerm('inventory.manage') && createSameClinic();
      allow update: if hasPerm('inventory.manage')
        && sameClinic() && createSameClinic();
      allow delete: if hasPerm('inventory.manage') && sameClinic();
    }

    // ---- клиники (реестр тенантов) ----
    // Читать реестр может любой активный сотрудник (напр. чтобы показать имя
    // своей клиники); заводить/править/удалять клиники — только платформенный
    // администратор.
    match /clinics/{id} {
      allow read: if isActive();
      allow create, update, delete: if isPlatform();
    }

    // ---- deny-by-default: всё остальное закрыто ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
